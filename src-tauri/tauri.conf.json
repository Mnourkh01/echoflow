{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EchoFlow",
  "version": "0.1.0",
  "identifier": "com.voiceapp.beta",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "EchoFlow",
        "width": 1040,
        "height": 720,
        "minWidth": 820,
        "minHeight": 560
      },
      {
        "label": "overlay",
        "title": "Voice",
        "width": 150,
        "height": 40,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "focus": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data: blob:; media-src 'self' asset: http://asset.localhost blob:; style-src 'self' 'unsafe-inline'; script-src 'self'",
      "devCsp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost ws://localhost:1420 http://localhost:1420; img-src 'self' asset: http://asset.localhost data: blob:; media-src 'self' asset: http://asset.localhost blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["$APPDATA/audio/**"]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "publisher": "EchoFlow",
    "copyright": "Copyright © 2026 EchoFlow",
    "category": "Productivity",
    "shortDescription": "Offline English & Arabic voice to text",
    "longDescription": "EchoFlow turns speech into text on your PC, fully offline. English and Arabic with automatic language and dialect detection, push-to-talk, and history.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "languages": ["English", "Arabic"],
        "displayLanguageSelector": true
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU3NDQ4NkIwN0U1OTk5NjAKUldSZ21WbCtzSVpFNTBBd3dubGU0Y09RM3VCRzIrMW5jdzRiZEs2N2hjdjNMdVdhdUNLUVBSQUIK",
      "endpoints": [
        "https://github.com/Mnourkh01/echoflow/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
